{
  "name": "@xianzhen2008-dotcom/teamchat",
  "version": "1.1.0",
  "description": "Open-source multi-agent team chat workspace with realtime messaging, action logs, PWA, and Android packaging.",
  "type": "module",
  "main": "team_chat_server.cjs",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "start": "node team_chat_server.cjs",
    "pwa:build": "npm run build",
    "icons:generate": "python3 ./scripts/generate_app_icons.py",
    "cap:sync": "./node_modules/@capacitor/cli/bin/capacitor sync",
    "cap:open:android": "./node_modules/@capacitor/cli/bin/capacitor open android",
    "cap:add:android": "./node_modules/@capacitor/cli/bin/capacitor add android",
    "apk:prepare": "npm run icons:generate && npm run build && npm run cap:sync",
    "check:clean": "node ./scripts/check_open_source_clean.cjs",
    "version": "node update-version.cjs",
    "version:increment": "node update-version.cjs --increment"
  },
  "keywords": [
    "ai",
    "agent",
    "collaboration",
    "multi-agent",
    "openclaw",
    "websocket",
    "real-time"
  ],
  "author": "OpenClaw Team",
  "license": "MIT",
  "homepage": "https://github.com/xianzhen2008-dotcom/teamchat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xianzhen2008-dotcom/teamchat.git"
  },
  "bugs": {
    "url": "https://github.com/xianzhen2008-dotcom/teamchat/issues"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.4.23"
    },
    "install": {
      "minHostVersion": ">=2026.3.22"
    }
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "dotenv": "^17.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "esbuild": "^0.28.0",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
