# TeamChat open-source defaults

# Server
TEAMCHAT_PORT=18788
TEAMCHAT_DATA_DIR=./data
TEAMCHAT_PUBLIC_BASE_URL=http://localhost:18788

# Authentication
# none: local/demo friendly. password: require TEAMCHAT_PASSWORD.
TEAMCHAT_AUTH_MODE=none
TEAMCHAT_PASSWORD=

# Demo mode seeds a clean local conversation when no data file exists.
TEAMCHAT_DEMO_MODE=true
TEAMCHAT_DEMO_MODEL=demo-agent

# Optional adapters. Disabled by default so the repository is runnable without
# private OpenClaw, chat-channel, or tunnel infrastructure.
TEAMCHAT_GATEWAY_ENABLED=false
TEAMCHAT_GATEWAY_TOKEN=
TEAMCHAT_WECOM_ENABLED=false
TEAMCHAT_WEIXIN_ENABLED=false
TEAMCHAT_FEISHU_ENABLED=false
TEAMCHAT_TELEGRAM_ENABLED=false
TEAMCHAT_TUNNEL_ENABLED=false

# Setup wizard and local discovery
TEAMCHAT_AVATAR_DIR=./public/assets/avatars
TEAMCHAT_AGENTS_JSON=./config/agents.json
TEAMCHAT_AGENT_DISCOVERY_PATHS=./agents,./config/agents.json
TEAMCHAT_CHANNELS=teamchat,tui,telegram,wecom,weixin,feishu,qqbot
