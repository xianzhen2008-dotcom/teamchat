import { MetricsDashboard } from './modules/dashboard/metrics.js?v=81';
import { StatusDashboard } from './modules/dashboard/status.js?v=81';

const LOCAL_STORAGE_KEY = 'teamchat_messages';
const AGENT_MODEL_CONFIG = {
    'main': 'gpt-4',
    'dev': 'claude-3-opus',
    'qa': 'gemini-pro',
    'mail': 'gpt-4',
    'data': 'gpt-4',
    'writer': 'claude-3-opus',
    'pm': 'gpt-4'
};

const AGENT_NAMES = {
    'main': '小龙虾',
    'dev': '小码',
    'qa': '小测',
    'mail': '小邮',
    'data': '小数',
    'writer': '小文',
    'pm': '小产',
    'finance': '小财',
    'devops': '小运',
    'mobile': '小移',
    'frontend': '小前',
    'backend': '小后'
};

// 导出到 window 对象供其他模块使用
window.AGENT_NAMES = AGENT_NAMES;

const AGENT_ORDER = [
    'main', 'qa', 'mail', 'data', 'writer', 'pm', 
    'dev', 'finance', 'devops', 'mobile', 'frontend', 'backend'
];

const AGENT_ICONS = {
    'main': '🦞',
    'dev': '💻',
    'qa': '🧪',
    'mail': '📧',
    'data': '📊',
    'writer': '✍️',
    'pm': '📋',
    'finance': '💰',
    'devops': '🚀',
    'mobile': '📱',
    'frontend': '🎨',
    'backend': '⚙️'
};

let messages = [];
let ws = null;
let metricsDashboard = null;
let statusDashboard = null;
let scrollLocked = false;
let agents = [];
let selectedAgentId = null;
let filterAgents = new Set();
let reconnectTimer = null;
let heartbeatTimer = null;
let mentionSelectedIndex = 0;

function getAgentModel(agentId, sender) {
    return AGENT_MODEL_CONFIG[agentId] || AGENT_MODEL_CONFIG[sender] || 'gpt-4';
}

function getAgentDisplayName(agentId) {
    return AGENT_NAMES[agentId] || agentId || '未知';
}

function getAgentIcon(agentId) {
    return AGENT_ICONS[agentId] || '🤖';
}

function getMessageId(msg) {
    return `${msg.timestamp}-${msg.sender}-${(msg.text || '').substring(0, 20)}`;
}

async function syncMessagesWithServer(force = false) {
    console.log('[Sync] Starting message sync...');
    
    const startTime = Date.now();
    let latency = 0;
    
    try {
        const localMessages = loadLocalMessages();
        const pingStart = Date.now();
        
        const response = await fetch('/history');
        latency = Date.now() - pingStart;
        const serverHistory = await response.json();
        
        const localMessageIds = new Set(localMessages.map(getMessageId));
        const serverMessageIds = new Set(serverHistory.map(getMessageId));
        
        const newFromServer = serverHistory.filter(m => !localMessageIds.has(getMessageId(m)));
        const onlyLocal = localMessages.filter(m => !serverMessageIds.has(getMessageId(m)));
        
        console.log(`[Sync] Server: ${serverHistory.length}, Local: ${localMessages.length}, New: ${newFromServer.length}`);
        
        if (metricsDashboard && metricsDashboard.syncStatus) {
            metricsDashboard.syncStatus.serverCount = serverHistory.length;
            metricsDashboard.syncStatus.localCount = localMessages.length;
            metricsDashboard.syncStatus.diff = newFromServer.length;
            metricsDashboard.syncStatus.latency = latency;
            metricsDashboard.syncStatus.lastSyncTime = Date.now();
            metricsDashboard.syncStatus.error = null;
            metricsDashboard.updateSyncStatus();
        }
        
        if (newFromServer.length > 0 || force) {
            let allMessages = [...serverHistory];
            
            onlyLocal.forEach(msg => {
                const existsInServer = serverHistory.some(sm => 
                    sm.timestamp === msg.timestamp && sm.sender === msg.sender
                );
                if (!existsInServer) {
                    allMessages.push(msg);
                }
            });
            
            allMessages = deduplicateMessages(allMessages);
            allMessages.sort((a, b) => a.timestamp - b.timestamp);
            
            saveLocalMessages(allMessages);
            messages = allMessages;
            renderMessages();
        }
        
        const totalTime = Date.now() - startTime;
        console.log(`[Sync] Complete in ${totalTime}ms (latency: ${latency}ms)`);
        
    } catch (e) {
        console.error('[Sync] Error:', e);
        if (metricsDashboard && metricsDashboard.syncStatus) {
            metricsDashboard.syncStatus.error = e.message;
            metricsDashboard.updateSyncStatus();
        }
    }
}

function deduplicateMessages(msgs) {
    const seen = new Map();
    msgs.forEach(msg => {
        const id = getMessageId(msg);
        if (!seen.has(id)) {
            seen.set(id, msg);
        }
    });
    return Array.from(seen.values());
}

function loadLocalMessages() {
    try {
        const stored = localStorage.getItem(LOCAL_STORAGE_KEY);
        return stored ? JSON.parse(stored) : [];
    } catch (e) {
        console.error('[LocalStorage] Load error:', e);
        return [];
    }
}

function saveLocalMessages(msgs) {
    try {
        localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify(msgs));
    } catch (e) {
        console.error('[LocalStorage] Save error:', e);
    }
}

async function loadAgents() {
    try {
        const response = await fetch('/api/agents');
        agents = await response.json();
        renderAgentList();
    } catch (e) {
        console.error('[Agents] Load error:', e);
        agents = [];
    }
}

function renderAgentList() {
    const container = document.getElementById('agent-list');
    if (!container) return;
    
    const sortedAgents = [...agents].sort((a, b) => {
        const orderA = AGENT_ORDER.indexOf(a.id);
        const orderB = AGENT_ORDER.indexOf(b.id);
        if (orderA === -1 && orderB === -1) return 0;
        if (orderA === -1) return 1;
        if (orderB === -1) return -1;
        return orderA - orderB;
    });
    
    container.innerHTML = sortedAgents.map(agent => {
        const isBusy = agent.status === 'busy';
        const isOnline = agent.status === 'online' || agent.status === 'stale';
        
        let statusClass = '';
        let statusText = '待命';
        
        if (isBusy) {
            statusClass = 'online busy';
            statusText = '工作中...';
        } else if (isOnline) {
            statusClass = 'online';
            statusText = '待命';
        }
        
        return `
        <div class="agent-item ${agent.id === selectedAgentId ? 'active' : ''} ${isBusy ? 'working' : ''}" 
             data-agent-id="${agent.id}">
            <div class="agent-avatar-wrap">
                <div class="agent-avatar" style="background-image: url('/images/${getAgentDisplayName(agent.id)}.png')"></div>
                <div class="agent-presence ${statusClass}"></div>
            </div>
            <div class="agent-info">
                <div class="agent-name">${agent.name || getAgentDisplayName(agent.id)}</div>
                <div class="agent-status ${statusClass}">${statusText}</div>
            </div>
        </div>
    `}).join('');
    
    container.querySelectorAll('.agent-item').forEach(item => {
        item.addEventListener('click', () => {
            const agentId = item.dataset.agentId;
            selectAgent(agentId);
        });
    });
}

function selectAgent(agentId) {
    selectedAgentId = agentId;
    
    document.querySelectorAll('.agent-item').forEach(item => {
        item.classList.toggle('active', item.dataset.agentId === agentId);
    });
    
    const chatInput = document.getElementById('chat-input');
    if (chatInput) {
        const agent = agents.find(a => a.id === agentId);
        const agentName = agent?.name || getAgentDisplayName(agentId);
        chatInput.value = `@${agentName} `;
        chatInput.focus();
    }
    
    if (window.innerWidth <= 768) {
        document.getElementById('sidebar')?.classList.add('sidebar-collapsed');
    }
}

function mentionAgent(agentName) {
    const chatInput = document.getElementById('chat-input');
    if (chatInput) {
        chatInput.value = `@${agentName} `;
        chatInput.focus();
    }
}

function renderMessages() {
    const container = document.getElementById('messages-view');
    if (!container) return;
    
    let filteredMessages = messages;
    if (filterAgents.size > 0) {
        filteredMessages = messages.filter(msg => {
            const agentId = msg.agentId || msg.sender;
            return filterAgents.has(agentId) || msg.isUser;
        });
    }
    
    container.innerHTML = filteredMessages.map(msg => renderMessage(msg)).join('');
    
    container.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const msgEl = e.target.closest('.msg');
            const content = msgEl.querySelector('.msg-content').textContent;
            navigator.clipboard.writeText(content).then(() => {
                btn.textContent = '✓';
                setTimeout(() => btn.textContent = '📋', 1000);
            });
        });
    });
    
    container.querySelectorAll('.quote-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const msgEl = e.target.closest('.msg');
            const content = msgEl.querySelector('.msg-content').textContent;
            const sender = msgEl.querySelector('.msg-sender').textContent;
            const chatInput = document.getElementById('chat-input');
            if (chatInput) {
                chatInput.value += `\n> ${sender}: ${content}\n`;
                chatInput.focus();
            }
        });
    });
    
    container.querySelectorAll('.recall-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const msgEl = e.target.closest('.msg');
            const msgId = msgEl.dataset.msgId;
            const idx = messages.findIndex(m => m.timestamp == msgId);
            if (idx !== -1) {
                messages.splice(idx, 1);
                saveLocalMessages(messages);
                renderMessages();
            }
        });
    });
    
    if (!scrollLocked) {
        container.scrollTop = container.scrollHeight;
    }
}

function renderMessage(msg) {
    const isUser = msg.isUser === true || msg.sender === '用户';
    const time = new Date(msg.timestamp).toLocaleTimeString();
    const agentId = msg.agentId || msg.sender || '未知';
    
    // 查找 agent 数据
    let agent = agents.find(a => a.id === agentId);
    if (!agent) {
        agent = agents.find(a => a.name === msg.sender);
    }
    if (!agent) {
        agent = agents.find(a => AGENT_NAMES[a.id] === msg.sender);
    }
    
    // 获取显示名字
    let displayName;
    if (isUser) {
        displayName = '用户';
    } else if (agent?.name) {
        displayName = agent.name;
    } else if (AGENT_NAMES[agentId]) {
        displayName = AGENT_NAMES[agentId];
    } else if (AGENT_NAMES[msg.sender]) {
        displayName = AGENT_NAMES[msg.sender];
    } else {
        displayName = msg.sender || agentId;
    }
    
    // 计算头像 URL
    let avatarUrl;
    if (isUser) {
        // 用户消息使用默认头像
        avatarUrl = '/images/小龙虾.png';
    } else {
        // Agent 消息使用对应中文名字的头像
        const avatarName = AGENT_NAMES[agent?.id || agentId] || displayName;
        avatarUrl = `/images/${avatarName}.png`;
    }
    
    const isWorking = agent?.status === 'busy';
    
    let modelHtml = '';
    if (!isUser) {
        const modelId = msg.modelInfo?.modelId || agent?.modelId || getAgentModel(agent?.id || agentId);
        modelHtml = `<span class="msg-model">${modelId}</span>`;
    }
    
    const status = msg.status || 'sent';
    const statusText = {
        'sending': '发送中...',
        'sent': '',
        'failed': '发送失败',
        'pending': '待处理',
        'processed': '已处理'
    }[status] || '';
    
    return `
        <div class="msg ${isUser ? 'user' : 'agent'}" data-msg-id="${msg.timestamp}" data-status="${status}">
            <div class="msg-avatar-wrap">
                <div class="msg-avatar ${isWorking ? 'working' : ''}" 
                     style="background-image: url('${avatarUrl}')" 
                     data-agent-name="${displayName}"
                     onclick="mentionAgent('${displayName}')"
                     onerror="this.style.backgroundImage='url(/images/小龙虾.png)'"></div>
            </div>
            <div class="msg-body">
                <div class="msg-meta">
                    <span class="msg-sender">${displayName}</span>
                    <span class="msg-time">${time}</span>
                    ${modelHtml}
                    ${statusText ? `<span class="msg-status">${statusText}</span>` : ''}
                </div>
                <div class="msg-content">${renderMessageContent(msg.text || '')}</div>
            </div>
            <div class="msg-actions">
                <button class="msg-action-btn copy-btn" title="复制">📋</button>
                <button class="msg-action-btn quote-btn" title="引用">💬</button>
                ${status === 'pending' ? '<button class="msg-action-btn recall-btn" title="撤回">↩️</button>' : ''}
            </div>
        </div>
    `;
}

function renderMessageContent(text) {
    const div = document.createElement('div');
    div.textContent = text;
    const escaped = div.innerHTML;
    
    return escaped
        .replace(/\n/g, '<br>')
        .replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank">$1</a>')
        .replace(/@([\u4e00-\u9fa5\w]+)/g, '<span class="mention">@$1</span>');
}

function connectWebSocket() {
    if (reconnectTimer) {
        clearTimeout(reconnectTimer);
        reconnectTimer = null;
    }
    
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = `${protocol}//${window.location.host}/ws`;
    
    console.log('[WebSocket] Connecting to', wsUrl);
    ws = new WebSocket(wsUrl);
    
    ws.onopen = () => {
        console.log('[WebSocket] Connected');
        updateConnectionStatus(true);
        startHeartbeat();
    };
    
    ws.onmessage = (event) => {
        try {
            const msg = JSON.parse(event.data);
            handleNewMessage(msg);
        } catch (e) {
            console.error('[WebSocket] Parse error:', e);
        }
    };
    
    ws.onclose = () => {
        console.log('[WebSocket] Disconnected');
        updateConnectionStatus(false);
        stopHeartbeat();
        reconnectTimer = setTimeout(connectWebSocket, 3000);
    };
    
    ws.onerror = (error) => {
        console.error('[WebSocket] Error:', error);
    };
}

function startHeartbeat() {
    stopHeartbeat();
    heartbeatTimer = setInterval(() => {
        if (ws && ws.readyState === WebSocket.OPEN) {
            ws.send(JSON.stringify({ type: 'ping' }));
        }
    }, 30000);
}

function stopHeartbeat() {
    if (heartbeatTimer) {
        clearInterval(heartbeatTimer);
        heartbeatTimer = null;
    }
}

function handleNewMessage(msg) {
    if (!msg.sender || !msg.text) {
        console.log('[DEBUG] Ignoring non-chat message:', msg.type || msg.event);
        return;
    }
    
    if (!msg.timestamp) msg.timestamp = Date.now();
    
    const msgId = getMessageId(msg);
    const exists = messages.some(m => getMessageId(m) === msgId);
    if (exists) {
        console.log('[DEBUG] Duplicate message ignored');
        return;
    }
    
    if (!msg.modelInfo && !msg.isUser) {
        const agentId = msg.agentId || msg.sender;
        const modelId = getAgentModel(agentId, msg.sender);
        msg.modelInfo = {
            modelId: modelId,
            calls: 1,
            inputTokens: 0,
            outputTokens: 0
        };
    }
    
    messages.push(msg);
    saveLocalMessages(messages);
    renderMessages();
    
    if (metricsDashboard && metricsDashboard.metrics) {
        metricsDashboard.metrics.totalMessages++;
        metricsDashboard.updateDisplay();
    }
}

function updateConnectionStatus(connected) {
    const statusEl = document.getElementById('connection-status');
    if (statusEl) {
        statusEl.className = `connection-status ${connected ? 'connected' : ''}`;
    }
}

function initUI() {
    metricsDashboard = new MetricsDashboard();
    metricsDashboard.init();
    
    statusDashboard = new StatusDashboard();
    statusDashboard.init();
    
    document.getElementById('status-toggle')?.addEventListener('click', () => {
        statusDashboard.show();
    });
    
    document.getElementById('metrics-toggle')?.addEventListener('click', () => {
        metricsDashboard.show();
    });
    
    document.getElementById('scroll-lock-toggle')?.addEventListener('click', (e) => {
        scrollLocked = !scrollLocked;
        e.target.textContent = scrollLocked ? '🔒' : '🔓';
    });
    
    document.getElementById('menu-toggle')?.addEventListener('click', () => {
        document.getElementById('sidebar')?.classList.toggle('sidebar-collapsed');
    });
    
    document.getElementById('sidebar-overlay')?.addEventListener('click', () => {
        document.getElementById('sidebar')?.classList.add('sidebar-collapsed');
    });
    
    const moreToggle = document.getElementById('more-toggle');
    const headerDropdown = document.getElementById('header-dropdown');
    if (moreToggle && headerDropdown) {
        moreToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            headerDropdown.classList.toggle('visible');
        });
        
        document.addEventListener('click', () => {
            headerDropdown.classList.remove('visible');
        });
    }
    
    const sendBtn = document.getElementById('send-btn');
    const chatInput = document.getElementById('chat-input');
    if (sendBtn && chatInput) {
        sendBtn.addEventListener('click', sendMessage);
        chatInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
        
        initMentionFeature(chatInput);
    }
    
    initFilterPanel();
    initSearch();
    initThemeToggle();
}

function initMentionFeature(input) {
    let mentionMenu = document.getElementById('mention-menu');
    if (!mentionMenu) {
        mentionMenu = document.createElement('div');
        mentionMenu.id = 'mention-menu';
        mentionMenu.className = 'mention-menu';
        document.body.appendChild(mentionMenu);
    }
    
    let currentFilter = '';
    let isMenuVisible = false;
    
    function updateMenu(filter = '') {
        currentFilter = filter.toLowerCase();
        const filteredAgents = agents.filter(agent => {
            const name = (agent.name || getAgentDisplayName(agent.id)).toLowerCase();
            return name.includes(currentFilter);
        });
        
        if (filteredAgents.length === 0) {
            mentionMenu.classList.remove('visible');
            isMenuVisible = false;
            return;
        }
        
        mentionSelectedIndex = 0;
        
        mentionMenu.innerHTML = filteredAgents.map((agent, index) => `
            <div class="mention-item ${index === 0 ? 'selected' : ''}" data-agent-id="${agent.id}">
                <div class="mention-avatar" style="background-image: url('/images/${getAgentDisplayName(agent.id)}.png')"></div>
                <span class="mention-name">${agent.name || getAgentDisplayName(agent.id)}</span>
            </div>
        `).join('');
        
        mentionMenu.querySelectorAll('.mention-item').forEach((item, index) => {
            item.addEventListener('click', () => {
                selectMentionAgent(filteredAgents[index]);
            });
            item.addEventListener('mouseenter', () => {
                mentionSelectedIndex = index;
                updateSelection();
            });
        });
        
        const rect = input.getBoundingClientRect();
        mentionMenu.style.left = rect.left + 'px';
        mentionMenu.style.top = (rect.top - Math.min(filteredAgents.length * 40 + 10, 200)) + 'px';
        
        mentionMenu.classList.add('visible');
        isMenuVisible = true;
    }
    
    function updateSelection() {
        mentionMenu.querySelectorAll('.mention-item').forEach((item, index) => {
            item.classList.toggle('selected', index === mentionSelectedIndex);
        });
    }
    
    function selectMentionAgent(agent) {
        const agentName = agent?.name || getAgentDisplayName(agent.id);
        const value = input.value;
        const cursorPos = input.selectionStart;
        const lastAtIndex = value.lastIndexOf('@');
        
        if (lastAtIndex !== -1) {
            const newValue = value.substring(0, lastAtIndex) + `@${agentName} ` + value.substring(cursorPos);
            input.value = newValue;
            input.focus();
            const newCursorPos = lastAtIndex + agentName.length + 2;
            input.setSelectionRange(newCursorPos, newCursorPos);
        }
        
        mentionMenu.classList.remove('visible');
        isMenuVisible = false;
    }
    
    function hideMenu() {
        mentionMenu.classList.remove('visible');
        isMenuVisible = false;
    }
    
    input.addEventListener('input', (e) => {
        const value = input.value;
        const cursorPos = input.selectionStart;
        const textBeforeCursor = value.substring(0, cursorPos);
        
        const lastAtIndex = textBeforeCursor.lastIndexOf('@');
        
        if (lastAtIndex !== -1) {
            const textAfterAt = textBeforeCursor.substring(lastAtIndex + 1);
            
            if (!textAfterAt.includes(' ') && !textAfterAt.includes('\n')) {
                updateMenu(textAfterAt);
                return;
            }
        }
        
        hideMenu();
    });
    
    input.addEventListener('keydown', (e) => {
        if (!isMenuVisible) return;
        
        const visibleItems = mentionMenu.querySelectorAll('.mention-item');
        if (visibleItems.length === 0) return;
        
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            mentionSelectedIndex = (mentionSelectedIndex + 1) % visibleItems.length;
            updateSelection();
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            mentionSelectedIndex = (mentionSelectedIndex - 1 + visibleItems.length) % visibleItems.length;
            updateSelection();
        } else if (e.key === 'Enter') {
            e.preventDefault();
            const selected = visibleItems[mentionSelectedIndex];
            if (selected) {
                const agentId = selected.dataset.agentId;
                const agent = agents.find(a => a.id === agentId);
                selectMentionAgent(agent);
            }
        } else if (e.key === 'Escape') {
            e.preventDefault();
            hideMenu();
        }
    });
    
    document.addEventListener('click', (e) => {
        if (!mentionMenu.contains(e.target) && e.target !== input) {
            hideMenu();
        }
    });
}

function initThemeToggle() {
    const themeToggle = document.getElementById('theme-toggle-2');
    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const body = document.body;
            const darkTheme = document.getElementById('theme-dark');
            const lightTheme = document.getElementById('theme-light');
            
            if (body.dataset.theme === 'dark') {
                body.dataset.theme = 'light';
                darkTheme.disabled = true;
                lightTheme.disabled = false;
            } else {
                body.dataset.theme = 'dark';
                darkTheme.disabled = false;
                lightTheme.disabled = true;
            }
        });
    }
}

function initFilterPanel() {
    const filterToggle = document.getElementById('filter-toggle');
    const filterPanel = document.getElementById('filter-panel');
    const filterOverlay = document.getElementById('filter-panel-overlay');
    const filterClose = filterPanel?.querySelector('.filter-panel-close');
    const filterGrid = document.getElementById('filter-agent-grid');
    const quickBtns = filterPanel?.querySelectorAll('.filter-quick-btn');
    
    filterToggle?.addEventListener('click', () => {
        filterPanel?.classList.toggle('show');
        filterOverlay?.classList.toggle('show');
        renderFilterAgents();
    });
    
    filterClose?.addEventListener('click', () => {
        filterPanel?.classList.remove('show');
        filterOverlay?.classList.remove('show');
    });
    
    filterOverlay?.addEventListener('click', () => {
        filterPanel?.classList.remove('show');
        filterOverlay?.classList.remove('show');
    });
    
    quickBtns?.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = btn.dataset.filter;
            if (filter === 'all') {
                filterAgents.clear();
            } else if (filter === 'dev') {
                filterAgents = new Set(['dev', 'frontend', 'backend', 'qa']);
            }
            quickBtns.forEach(b => b.classList.toggle('active', b === btn));
            renderMessages();
        });
    });
    
    function renderFilterAgents() {
        if (!filterGrid) return;
        filterGrid.innerHTML = agents.map(agent => `
            <div class="filter-agent-item ${filterAgents.has(agent.id) ? 'active' : ''}" data-agent-id="${agent.id}">
                <div class="filter-agent-avatar" style="background-image: url('/images/${getAgentDisplayName(agent.id)}.png')"></div>
                <div class="filter-agent-name">${agent.name || getAgentDisplayName(agent.id)}</div>
            </div>
        `).join('');
        
        filterGrid.querySelectorAll('.filter-agent-item').forEach(item => {
            item.addEventListener('click', () => {
                const agentId = item.dataset.agentId;
                if (filterAgents.has(agentId)) {
                    filterAgents.delete(agentId);
                } else {
                    filterAgents.add(agentId);
                }
                item.classList.toggle('active');
                renderMessages();
            });
        });
    }
}

function initSearch() {
    const searchToggle = document.getElementById('search-toggle');
    const searchContainer = document.getElementById('search-container');
    const searchInput = document.getElementById('search-input');
    const searchClose = searchContainer?.querySelector('.search-close');
    
    searchToggle?.addEventListener('click', () => {
        searchContainer?.classList.toggle('active');
        if (searchContainer?.classList.contains('active')) {
            searchInput?.focus();
        }
    });
    
    searchClose?.addEventListener('click', () => {
        searchContainer?.classList.remove('active');
        if (searchInput) searchInput.value = '';
        renderMessages();
    });
    
    searchInput?.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        if (!query) {
            renderMessages();
            return;
        }
        
        const filtered = messages.filter(msg => 
            (msg.text || '').toLowerCase().includes(query) ||
            (msg.sender || '').toLowerCase().includes(query)
        );
        
        const container = document.getElementById('messages-view');
        if (container) {
            container.innerHTML = filtered.map(msg => renderMessage(msg)).join('');
        }
    });
}

async function sendMessage() {
    const input = document.getElementById('chat-input');
    const text = input?.value.trim();
    if (!text) return;
    
    const msg = {
        isUser: true,
        sender: '用户',
        text: text,
        timestamp: Date.now()
    };
    
    handleNewMessage(msg);
    
    if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify(msg));
    } else {
        try {
            await fetch('/history', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(msg)
            });
        } catch (e) {
            console.error('[Send] Error:', e);
        }
    }
    
    input.value = '';
    input.style.height = 'auto';
}

async function init() {
    console.log('[TeamChat] Initializing...');

    messages = loadLocalMessages();
    
    initUI();

    await loadAgents();

    connectWebSocket();

    await syncMessagesWithServer(true);

    setInterval(() => {
        syncMessagesWithServer();
        loadAgents();
    }, 30000);

    console.log('[TeamChat] Ready');
}

window.syncMessagesWithServer = syncMessagesWithServer;
window.metricsDashboard = metricsDashboard;

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}
